{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SpecScan",
  "version": "0.2.2",
  "identifier": "com.ilanzgx.specscan",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "SpecScan",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "maximizable": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ilanzgx/SpecScan/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc1QUYyQTZEMkFEMEI1OUIKUldTYnRkQXFiU3F2ZFJXTDZZOHc5TG5HMnptbUNXMmNiV0NlYWJ0SnRLN0pkbURZVlc2N0tUc1QK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "resources/*.csv"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
